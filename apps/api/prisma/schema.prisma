// UZBooking — universal bron platformasi data modeli.
// MVP: hotel. Yangi vertikallar Category + UnitType orqali qo'shiladi (sxema o'zgarmaydi).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ListingStatus {
  DRAFT
  PENDING
  PUBLISHED
  HIDDEN
}

enum UnitType {
  NIGHTLY // sutkalik: mehmonxona, dacha
  SLOT // vaqt sloti: shifokor, sartarosh, sport
  TABLE // stol/joy: restoran
}

enum AvailabilityStatus {
  FREE
  BLOCKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  phone        String?  @unique
  email        String?  @unique
  googleId     String?  @unique
  passwordHash String?
  avatarUrl    String?
  name         String?
  birthday     DateTime? @db.Date
  gender       String?
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendor    Vendor?
  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]

  @@map("users")
}

/// Telefon OTP kodlari (kirish uchun)
model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@map("otp_codes")
}

/// Email tasdiqlash kodlari (biznes akkaunt 2FA uchun)
model EmailCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("email_codes")
}

/// Saqlanganlar (wishlist) — server tomonda
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@map("favorites")
}

/// Vertikal (kategoriya): hotel, restaurant, salon, ...
model Category {
  id     String  @id @default(cuid())
  key    String  @unique // CategoryKey: "hotel", "restaurant", ...
  nameUz String
  nameRu String?
  nameEn String?
  icon   String?
  active Boolean @default(true)
  sort   Int     @default(0)

  listings Listing[]

  @@map("categories")
}

/// Biznes egasi
model Vendor {
  id        String       @id @default(cuid())
  ownerId   String       @unique
  owner     User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  status    VendorStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  listings Listing[]

  @@map("vendors")
}

/// E'lon / obyekt (mehmonxona, restoran, klinika, ...)
model Listing {
  id          String        @id @default(cuid())
  vendorId    String
  vendor      Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  title       String
  description String?
  address     String?
  city        String?
  lat         Float?
  lng         Float?
  photos      String[]      @default([])
  attributes  Json          @default("{}") // vertikalga xos maydonlar
  rating      Float         @default(0)
  reviewCount Int           @default(0)
  status      ListingStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  units     BookableUnit[]
  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]

  @@index([categoryId, city, status])
  @@map("listings")
}

/// Bron birligi: xona / stol / slot
model BookableUnit {
  id         String   @id @default(cuid())
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name       String
  unitType   UnitType
  capacity   Int      @default(1)
  basePrice  Decimal  @db.Decimal(12, 2)
  attributes Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  availabilities Availability[]
  bookings       Booking[]

  @@index([listingId])
  @@map("bookable_units")
}

/// Bo'sh vaqt / narx kalendari. NIGHTLY uchun har bir sana bitta yozuv.
model Availability {
  id        String             @id @default(cuid())
  unitId    String
  unit      BookableUnit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  date      DateTime           @db.Date
  startTime String? // SLOT/TABLE uchun "HH:MM"
  endTime   String?
  price     Decimal?           @db.Decimal(12, 2) // null = unit.basePrice
  status    AvailabilityStatus @default(FREE)

  // Bir birlik uchun bir sana+vaqt sloti unik — ikki marta band bo'lishdan saqlaydi
  @@unique([unitId, date, startTime])
  @@index([unitId, date])
  @@map("availabilities")
}

/// Bron
model Booking {
  id         String        @id @default(cuid())
  customerId String
  customer   User          @relation(fields: [customerId], references: [id])
  listingId  String
  listing    Listing       @relation(fields: [listingId], references: [id])
  unitId     String
  unit       BookableUnit  @relation(fields: [unitId], references: [id])
  startDate  DateTime      @db.Date
  endDate    DateTime?     @db.Date
  startTime  String?
  endTime    String?
  guests     Int           @default(1)
  totalPrice Decimal       @db.Decimal(12, 2)
  status     BookingStatus @default(PENDING)
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  review Review?

  @@index([customerId])
  @@index([listingId, status])
  @@map("bookings")
}

/// Sharh — tugagan bron uchun
model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@index([listingId])
  @@map("reviews")
}
