# Postgres (docker-compose bilan mos)
DATABASE_URL="postgresql://uzbooking:uzbooking@localhost:5432/uzbooking?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# OTP (dev rejimida konsolga chiqadi; prod: Eskiz.uz / Play Mobile)
OTP_DEV_MODE=true

# Redis (keyingi bosqich)
REDIS_URL="redis://localhost:6379"

# MinIO / S3 (keyingi bosqich)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="uzbooking"
S3_SECRET_KEY="uzbooking123"
S3_BUCKET="uzbooking"
